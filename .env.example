# Copy this file's values into your actual deployment config.
# Never commit a real .env file with real keys to a public repo.

# Google Gemini (free tier) - get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Telegram bot alerts - create a bot via @BotFather, then get your chat id
# by messaging the bot and visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Persistent database (fixes data disappearing after every deploy).
# Get a free permanent Postgres DB at https://neon.tech (no card, no expiry).
# Create a project, copy the connection string, paste it here.
# If left blank, falls back to a local SQLite file (data will NOT persist
# across Render restarts/redeploys -- fine for local testing only).
DATABASE_URL=postgresql://user:password@host/dbname

# Admin portal password (pick your own strong password)
ADMIN_PASSWORD=change-me-to-something-strong

# Flask session secret (any long random string)
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Stripe billing (for the subscription paywall) - get these from https://dashboard.stripe.com
# STRIPE_SECRET_KEY: Developers > API keys > Secret key
# STRIPE_PRICE_ID: Product catalog > create a product with a recurring monthly price > copy its Price ID
# STRIPE_WEBHOOK_SECRET: Developers > Webhooks > add endpoint https://your-app-url/api/billing/webhook > copy signing secret
STRIPE_SECRET_KEY=sk_live_or_sk_test_your_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
